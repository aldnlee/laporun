---
import Layout from '../layouts/Layout.astro'; // Pastikan ada file Layout.astro
import { supabase } from '../lib/supabase';

// Ambil data dari Supabase (Server Side)
const { data: activities, error } = await supabase
  .from('activities')
  .select('*')
  .order('created_at', { ascending: false });

const totalKm = activities?.reduce((acc, curr) => acc + curr.distance, 0) || 0;
---

<Layout title="Ngabuburun - Dashboard">
  <main class="p-6 max-w-xl mx-auto font-sans">
    <header class="flex justify-between items-center mb-8">
      <h1 class="text-3xl font-extrabold text-orange-600">Ngabuburun 🏃‍♂️</h1>
      <a href="/tracker" class="bg-orange-500 text-white px-4 py-2 rounded-full font-bold">+ Lari</a>
    </header>

    <section class="grid grid-cols-2 gap-4 mb-8">
      <div class="bg-orange-50 p-4 rounded-2xl border border-orange-100">
        <p class="text-sm text-gray-500">Total Jarak</p>
        <p class="text-2xl font-bold">{totalKm.toFixed(2)} <span class="text-sm">KM</span></p>
      </div>
      <div class="bg-blue-50 p-4 rounded-2xl border border-blue-100">
        <p class="text-sm text-gray-500">Total Sesi</p>
        <p class="text-2xl font-bold">{activities?.length || 0}</p>
      </div>
    </section>

    <section>
      <h2 class="font-bold mb-4">Aktivitas Terakhir</h2>
      <div class="space-y-4">
        {activities?.map((run) => (
          <a href={`/run/${run.id}`} class="block bg-white border p-4 rounded-xl hover:shadow-md transition">
            <div class="flex justify-between items-center">
              <div>
                <p class="font-bold text-lg">{run.title || 'Lari Santai'}</p>
                <p class="text-sm text-gray-400">{new Date(run.created_at).toLocaleDateString('id-ID')}</p>
              </div>
              <div class="text-right">
                <p class="font-bold">{run.distance.toFixed(2)} km</p>
                <p class="text-xs text-gray-500">{Math.floor(run.duration / 60)} menit</p>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>
  </main>
</Layout>
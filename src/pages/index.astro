---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Dashboard - Laporun">
  <div id="global-loader" class="fixed inset-0 bg-white z-[9999] flex items-center justify-center">
    <p class="text-orange-600 font-black italic animate-bounce uppercase tracking-widest">Ngabuburun...</p>
  </div>

  <main id="dashboard-content" class="hidden p-6 max-w-5xl mx-auto font-sans bg-gray-50 min-h-screen">
    <header class="flex justify-between items-center mb-8">
      <div>
        <h1 class="text-2xl font-black italic text-orange-600 tracking-tighter uppercase">Dashboard</h1>
        <p id="user-name" class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Welcome back!</p>
      </div>
      <div class="flex items-center gap-4 bg-white p-2 pr-4 rounded-full shadow-sm border border-gray-100">
        <img id="user-avatar" src="" class="w-8 h-8 rounded-full border border-orange-100 hidden" />
        <button id="logout-btn" class="text-[10px] font-black text-gray-400 hover:text-red-500 uppercase">Logout</button>
      </div>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <aside class="space-y-6">
        <div class="bg-white p-6 rounded-[32px] shadow-sm border border-gray-100">
          <h2 class="text-[10px] font-black text-gray-400 uppercase tracking-[0.2em] mb-6">Last 4 Weeks</h2>
          <div class="space-y-4">
            <div>
              <p id="stat-runs" class="text-3xl font-black text-gray-800">0</p>
              <p class="text-[10px] font-bold text-gray-400 uppercase">Total Runs</p>
            </div>
            <div>
              <p id="stat-dist" class="text-3xl font-black text-gray-800">0.0</p>
              <p class="text-[10px] font-bold text-gray-400 uppercase">Kilometers</p>
            </div>
          </div>
        </div>

        <div class="bg-orange-600 p-6 rounded-[32px] text-white shadow-xl shadow-orange-100">
           <h2 class="text-[10px] font-black opacity-70 uppercase tracking-[0.2em] mb-4 italic">Pro Tip</h2>
           <p class="text-xs font-bold leading-relaxed">Jaga konsistensi lari sore kamu, Den! Pace bukan segalanya, yang penting gerak.</p>
        </div>
      </aside>

      <section class="lg:col-span-2 space-y-4">
        <div class="flex justify-between items-center px-2">
          <h2 class="font-black italic text-gray-800 uppercase tracking-tight">Recent Runs</h2>
          <a href="/tracker" class="bg-orange-500 text-white px-6 py-2 rounded-full text-[10px] font-black shadow-lg shadow-orange-100">+ NEW RUN</a>
        </div>
        <div id="activities-list" class="space-y-4">
           <p class="text-center py-10 text-gray-300 italic">Loading your activities...</p>
        </div>
      </section>
    </div>
  </main>
</Layout>

<script>
  import { supabase } from '../lib/supabase';

  const loader = document.getElementById('global-loader');
  const content = document.getElementById('dashboard-content');
  const activitiesList = document.getElementById('activities-list');
  const logoutBtn = document.getElementById('logout-btn');

  async function initDashboard() {
    // 1. Cek Sesi
    const { data: { session } } = await supabase.auth.getSession();
    
    if (!session) {
      window.location.href = '/login';
      return;
    }

    // 2. Tampilkan User Info
    const user = session.user;
    (document.getElementById('user-name')!).innerText = `Athlete: ${user.user_metadata.full_name || user.email}`;
    const avatar = document.getElementById('user-avatar') as HTMLImageElement;
    avatar.src = user.user_metadata.avatar_url;
    avatar.classList.remove('hidden');

    // 3. Tarik Data Aktivitas
    const { data: activities, error } = await supabase
      .from('activities')
      .select('*')
      .eq('user_id', user.id)
      .order('created_at', { ascending: false });

    if (!error && activities) {
      // Hitung Stats Sederhana
      const totalDist = activities.reduce((acc, curr) => acc + curr.distance, 0);
      (document.getElementById('stat-runs')!).innerText = activities.length.toString();
      (document.getElementById('stat-dist')!).innerText = totalDist.toFixed(1);

      // Render List
      if (activities.length === 0) {
        activitiesList!.innerHTML = `<p class="text-center py-10 text-gray-400 uppercase text-[10px] font-black tracking-widest">No activities yet. Go for a run!</p>`;
      } else {
        activitiesList!.innerHTML = activities.map(run => `
          <a href="/run/${run.id}" class="block bg-white p-6 rounded-[32px] border border-gray-50 hover:border-orange-200 shadow-sm transition-all group">
            <div class="flex justify-between items-center">
              <div>
                <h3 class="font-black text-gray-800 text-xl italic uppercase group-hover:text-orange-600 transition-colors">${run.title}</h3>
                <p class="text-[10px] font-bold text-gray-400 mt-2 uppercase tracking-widest">${new Date(run.created_at).toLocaleDateString('id-ID')}</p>
              </div>
              <div class="text-right">
                <p class="text-3xl font-black text-gray-800">${run.distance.toFixed(2)}<span class="text-xs ml-1 text-gray-400 font-bold uppercase">km</span></p>
                <p class="text-[10px] font-black text-orange-500 uppercase italic mt-1">View Detail →</p>
              </div>
            </div>
          </a>
        `).join('');
      }
    }

    // Tampilkan konten, sembunyikan loader
    loader?.classList.add('hidden');
    content?.classList.remove('hidden');
  }

  logoutBtn?.addEventListener('click', async () => {
    await supabase.auth.signOut();
    window.location.href = '/login';
  });

  // Jalankan inisialisasi
  initDashboard();
</script>
---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Dashboard - Ngabuburun">
  <div id="global-loader" class="fixed inset-0 bg-white z-[9999] flex items-center justify-center">
    <p class="text-orange-600 font-black italic animate-bounce uppercase tracking-widest">Ngabuburun...</p>
  </div>

  <main id="dashboard-content" class="hidden p-6 max-w-5xl mx-auto font-sans bg-gray-50 min-h-screen">
    <header class="flex flex-col md:flex-row justify-between items-start md:items-center mb-10 gap-4">
      <div>
        <h1 class="text-3xl font-black italic text-orange-600 tracking-tighter uppercase leading-none">Athlete Dashboard</h1>
        <p id="user-name" class="text-[10px] font-bold text-gray-400 uppercase tracking-[0.3em] mt-2">Loading profile...</p>
      </div>
      
      <div class="flex items-center gap-4 bg-white p-2 pr-5 rounded-full shadow-sm border border-gray-100">
        <img id="user-avatar" src="" class="w-10 h-10 rounded-full border-2 border-orange-100 hidden" />
        <button id="logout-btn" class="text-[10px] font-black text-gray-400 hover:text-red-500 uppercase tracking-widest transition-colors">Logout</button>
      </div>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <aside class="space-y-6">
        <div class="bg-white p-8 rounded-[40px] shadow-sm border border-gray-100 relative overflow-hidden group">
          <div class="absolute -right-4 -top-4 text-orange-50 opacity-10 group-hover:scale-110 transition-transform">
            <svg width="120" height="120" fill="currentColor" viewBox="0 0 24 24"><path d="M13.5 5.5c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zM9.8 8.9L7 10.2l.6 3.5 1.8-1.5L10 16.5l2-1.6.7 3.6 2-1.2-.8-4.1-2.2-2.3 2.1-1.1 2 2.3 1.5-1.1-2.5-3-3.6 1.8-1.7-2.1-2.7 1.2z"/></svg>
          </div>
          <h2 class="text-[10px] font-black text-gray-400 uppercase tracking-[0.2em] mb-8">Personal Summary</h2>
          <div class="space-y-6">
            <div>
              <p id="stat-runs" class="text-5xl font-black text-gray-800 tracking-tighter">0</p>
              <p class="text-[10px] font-bold text-gray-400 uppercase mt-1">Total Activities</p>
            </div>
            <div>
              <p id="stat-dist" class="text-5xl font-black text-gray-800 tracking-tighter">0.0</p>
              <p class="text-[10px] font-bold text-gray-400 uppercase mt-1">Total Kilometers</p>
            </div>
          </div>
        </div>

        <div class="bg-orange-600 p-8 rounded-[40px] text-white shadow-2xl shadow-orange-200">
           <h3 class="text-[10px] font-black opacity-70 uppercase tracking-widest mb-4 italic">Action Centre</h3>
           <p class="text-sm font-bold leading-relaxed mb-6">Import data dari Garmin/Strava lewat GPX atau lari langsung sekarang!</p>
           
           <div class="flex flex-col gap-3">
             <label class="w-full cursor-pointer bg-orange-700 hover:bg-orange-800 text-white py-4 rounded-2xl text-xs font-black transition-all text-center uppercase tracking-widest">
               Import GPX File
               <input type="file" id="gpx-input" accept=".gpx" class="hidden" />
             </label>
             <a href="/tracker" class="w-full bg-white text-orange-600 py-4 rounded-2xl text-xs font-black text-center shadow-lg hover:scale-[1.02] transition-all uppercase tracking-widest">
               Start New Run
             </a>
           </div>
        </div>
      </aside>

      <section class="lg:col-span-2 space-y-4">
        <h2 class="font-black italic text-gray-800 uppercase tracking-tight ml-2">Recent Activities</h2>
        <div id="activities-list" class="space-y-4">
           <div class="animate-pulse flex flex-col gap-4">
             <div class="h-24 bg-gray-200 rounded-[32px]"></div>
             <div class="h-24 bg-gray-200 rounded-[32px]"></div>
           </div>
        </div>
      </section>
    </div>
  </main>
</Layout>

<script>
  import { supabase } from '../lib/supabase';
  import gpxParser from 'gpxparser';

  const loader = document.getElementById('global-loader');
  const content = document.getElementById('dashboard-content');
  const activitiesList = document.getElementById('activities-list');
  const gpxInput = document.getElementById('gpx-input') as HTMLInputElement;
  const logoutBtn = document.getElementById('logout-btn');

  async function initDashboard() {
    const { data: { session } } = await supabase.auth.getSession();
    
    if (!session) {
      window.location.href = '/login';
      return;
    }

    const user = session.user;
    (document.getElementById('user-name')!).innerText = `Athlete: ${user.user_metadata.full_name || user.email}`;
    const avatar = document.getElementById('user-avatar') as HTMLImageElement;
    avatar.src = user.user_metadata.avatar_url;
    avatar.classList.remove('hidden');

    await loadActivities(user.id);

    loader?.classList.add('hidden');
    content?.classList.remove('hidden');
  }

  async function loadActivities(userId: string) {
    const { data: activities, error } = await supabase
      .from('activities')
      .select('*')
      .eq('user_id', userId)
      .order('created_at', { ascending: false });

    if (!error && activities) {
      const totalDist = activities.reduce((acc, curr) => acc + curr.distance, 0);
      (document.getElementById('stat-runs')!).innerText = activities.length.toString();
      (document.getElementById('stat-dist')!).innerText = totalDist.toFixed(1);

      if (activities.length === 0) {
        activitiesList!.innerHTML = `
          <div class="text-center py-20 bg-white rounded-[40px] border-2 border-dashed border-gray-100">
            <p class="text-gray-300 font-black italic uppercase tracking-widest text-xs">No runs recorded yet.</p>
          </div>`;
      } else {
        activitiesList!.innerHTML = activities.map(run => `
          <a href="/run/${run.id}" class="block bg-white p-6 rounded-[32px] border border-gray-50 hover:border-orange-200 shadow-sm transition-all group active:scale-[0.98]">
            <div class="flex justify-between items-center">
              <div>
                <h3 class="font-black text-gray-800 text-xl italic uppercase group-hover:text-orange-600 transition-colors leading-none">${run.title}</h3>
                <p class="text-[10px] font-bold text-gray-400 mt-3 uppercase tracking-widest">
                  📅 ${new Date(run.created_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' })}
                </p>
              </div>
              <div class="text-right">
                <p class="text-3xl font-black text-gray-800 leading-none">${run.distance.toFixed(2)}<span class="text-xs ml-1 text-gray-400 font-bold uppercase italic">km</span></p>
                <p class="text-[10px] font-black text-orange-500 uppercase italic mt-2 tracking-tighter">View Stats →</p>
              </div>
            </div>
          </a>
        `).join('');
      }
    }
  }

  // LOGIC UPLOAD GPX
  gpxInput?.addEventListener('change', async (e) => {
    const file = (e.target as HTMLInputElement).files?.[0];
    if (!file) return;

    const reader = new FileReader();
    reader.onload = async (event) => {
      try {
        const gpxText = event.target?.result as string;
        const gpx = new gpxParser();
        gpx.parse(gpxText);

        const track = gpx.tracks[0];
        if (!track) throw new Error("File GPX tidak valid atau tidak ada track.");

        // AMBIL SEMUA KOORDINAT UNTUK PETA DETAIL
        const points = track.points.map(p => [p.lat, p.lon]);

        const distanceKm = track.distance.total / 1000;
        const startTime = track.points[0].time;
        const endTime = track.points[track.points.length - 1].time;
        let durationSec = 0;
        
        if (startTime && endTime) {
          durationSec = Math.floor((endTime.getTime() - startTime.getTime()) / 1000);
        }

        const title = prompt("Nama Aktivitas Import:", track.name || "Imported Run") || "Imported Run";
        
        const { data: { session } } = await supabase.auth.getSession();
        
        const { error } = await supabase.from('activities').insert([{
          title: title,
          distance: parseFloat(distanceKm.toFixed(2)),
          duration: durationSec,
          user_id: session?.user.id,
          route_data: points, // <--- UPDATE: Sekarang simpan rute juga
          created_at: startTime || new Date().toISOString()
        }]);

        if (!error) {
          alert("GPX Berhasil diimport!");
          window.location.reload();
        } else {
          throw error;
        }
      } catch (err: any) {
        alert("Gagal import GPX: " + err.message);
      }
    };
    reader.readAsText(file);
  });

  logoutBtn?.addEventListener('click', async () => {
    await supabase.auth.signOut();
    window.location.href = '/login';
  });

  initDashboard();
</script>

<style>
  #dashboard-content {
    animation: fadeIn 0.5s ease-out;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
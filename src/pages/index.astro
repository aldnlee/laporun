---
import Layout from '../layouts/Layout.astro';
import { supabase } from '../lib/supabase';

// Ambil data dari Supabase (Server Side)
const { data: activities, error } = await supabase
  .from('activities')
  .select('*')
  .order('created_at', { ascending: false });

// Hitung akumulasi statistik
const totalKm = activities?.reduce((acc, curr) => acc + (curr.distance || 0), 0) || 0;
const totalSessions = activities?.length || 0;

// Fungsi format durasi dari detik ke Menit:Detik
const formatDuration = (seconds: number) => {
  const min = Math.floor(seconds / 60);
  const sec = seconds % 60;
  return `${min}:${sec.toString().padStart(2, '0')}`;
};
---

<Layout title="Ngabuburun - Dashboard">
  <main class="p-6 max-w-xl mx-auto font-sans bg-white min-h-screen">
    
    <header class="flex justify-between items-center mb-10">
      <div>
        <h1 class="text-3xl font-black text-orange-600 italic">NGABUBURUN</h1>
        <p class="text-sm text-gray-500 font-medium">Kejar km sebelum adzan 🌙</p>
      </div>
      <a href="/tracker" class="bg-orange-500 hover:bg-orange-600 text-white w-12 h-12 rounded-full flex items-center justify-center shadow-lg shadow-orange-200 transition-transform active:scale-90">
        <span class="text-2xl font-bold">+</span>
      </a>
    </header>

    <section class="grid grid-cols-2 gap-4 mb-10">
      <div class="bg-orange-50 p-6 rounded-3xl border border-orange-100 shadow-sm">
        <p class="text-xs text-orange-400 uppercase font-bold tracking-wider mb-1">Total Jarak</p>
        <p class="text-3xl font-black text-gray-800">{totalKm.toFixed(2)} <span class="text-sm font-bold text-gray-400">KM</span></p>
      </div>
      <div class="bg-blue-50 p-6 rounded-3xl border border-blue-100 shadow-sm">
        <p class="text-xs text-blue-400 uppercase font-bold tracking-wider mb-1">Total Sesi</p>
        <p class="text-3xl font-black text-gray-800">{totalSessions} <span class="text-sm font-bold text-gray-400">Lari</span></p>
      </div>
    </section>

    <section>
      <div class="flex justify-between items-end mb-6">
        <h2 class="text-xl font-black text-gray-800 italic">Riwayat Lari</h2>
        <span class="text-xs text-gray-400 font-bold uppercase">Terbaru</span>
      </div>

      <div class="space-y-4">
        {error && <p class="text-red-500 text-center py-10">Gagal ambil data dari langit...</p>}
        
        {activities && activities.length === 0 && (
          <div class="text-center py-20 border-2 border-dashed border-gray-100 rounded-3xl">
            <p class="text-gray-400 font-medium">Belum ada lari hari ini.<br/>Yuk, mulai!</p>
          </div>
        )}

        {activities?.map((run) => (
          <div class="group bg-white border border-gray-100 p-5 rounded-3xl hover:border-orange-200 hover:shadow-xl hover:shadow-orange-50 transition-all">
            <div class="flex justify-between items-center">
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-orange-100 rounded-2xl flex items-center justify-center text-2xl">
                  🏃‍♂️
                </div>
                <div>
                  <p class="font-black text-gray-800 text-lg">{run.title || 'Ngabuburun'}</p>
                  <p class="text-xs text-gray-400 font-bold uppercase">
                    {new Date(run.created_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'short' })}
                  </p>
                </div>
              </div>
              <div class="text-right">
                <p class="text-xl font-black text-orange-600">{run.distance.toFixed(2)} <span class="text-xs">km</span></p>
                <p class="text-[10px] text-gray-400 font-bold uppercase tracking-tighter">⏱️ {formatDuration(run.duration)}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

  </main>
</Layout>
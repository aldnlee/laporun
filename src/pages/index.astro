---
import Layout from '../layouts/Layout.astro';
import { supabase } from '../lib/supabase';

const { data: activities } = await supabase
  .from('activities')
  .select('*')
  .order('created_at', { ascending: false });
---

<Layout title="Dashboard - Ngabuburun">
  <main class="p-6 max-w-xl mx-auto font-sans bg-white min-h-screen">
    <h1 class="text-3xl font-black text-orange-600 italic mb-6">HISTORY</h1>

    <div class="space-y-4">
      {activities?.map((run) => (
        <a href={`/activity/${run.id}`} class="block group bg-gray-50 border border-gray-100 p-5 rounded-3xl hover:border-orange-200 transition-all">
          <div class="flex justify-between items-center">
            <div>
              <p class="font-black text-gray-800 text-lg group-hover:text-orange-600">{run.title}</p>
              <p class="text-xs text-gray-400 font-bold uppercase">{new Date(run.created_at).toLocaleDateString()}</p>
            </div>
            <div class="text-right">
              <p class="text-xl font-black text-gray-800">{run.distance} km</p>
              <p class="text-[10px] text-gray-400 font-bold">DETAIL →</p>
            </div>
          </div>
        </a>
      ))}
    </div>

    <a href="/tracker" class="fixed bottom-10 right-10 bg-orange-500 text-white p-5 rounded-full shadow-2xl font-black">RUN</a>
  </main>
</Layout>
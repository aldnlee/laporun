---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="Dashboard - Ngabuburun">
  <script src="https://cdn.jsdelivr.net/npm/chart.js" is:inline></script>

  <style is:global>
    /* Fix Tailwind v4: Pastikan grid aktif saat hidden dilepas */
    #dashboard-content:not(.hidden) {
      display: grid !important;
    }
    @media (min-width: 1024px) {
      #dashboard-content:not(.hidden) {
        grid-template-columns: repeat(3, minmax(0, 1fr)) !important;
      }
    }
    canvas {
      width: 100% !important;
      height: 100% !important;
    }
    .animate-progress {
      animation: progress 2s ease-in-out infinite;
    }
    @keyframes progress {
      0% { transform: translateX(-100%); }
      100% { transform: translateX(100%); }
    }
  </style>

  <div id="global-loader" class="fixed inset-0 bg-white z-[9999] flex items-center justify-center">
    <div class="text-center">
      <p class="text-orange-600 font-black italic animate-bounce uppercase tracking-widest">Ngabuburun...</p>
      <div class="mt-2 h-1 w-24 bg-orange-100 rounded-full overflow-hidden relative">
        <div class="absolute inset-0 bg-orange-600 animate-progress"></div>
      </div>
    </div>
  </div>

  <main id="dashboard-content" class="hidden p-6 max-w-6xl mx-auto font-sans bg-gray-50 min-h-screen gap-8">
    
    <header class="col-span-1 lg:col-span-3 flex flex-col md:flex-row justify-between items-start md:items-center mb-2 gap-4">
      <div>
        <h1 class="text-3xl font-black italic text-orange-600 tracking-tighter uppercase leading-none italic">Athlete Dashboard</h1>
        <p id="user-name" class="text-[10px] font-bold text-gray-400 uppercase tracking-[0.3em] mt-2">Loading profile...</p>
      </div>
      
      <div class="flex items-center gap-4 bg-white p-2 pr-5 rounded-full shadow-sm border border-gray-100">
        <img id="user-avatar" src="" class="w-10 h-10 rounded-full border-2 border-orange-100 hidden" alt="Avatar" />
        <button id="logout-btn" class="text-[10px] font-black text-gray-400 hover:text-red-500 uppercase tracking-widest transition-colors cursor-pointer">Logout</button>
      </div>
    </header>

    <aside class="col-span-1 space-y-6">
      <div class="bg-white p-8 rounded-[40px] shadow-sm border border-gray-100 relative overflow-hidden group">
        <div class="absolute -right-4 -top-4 text-orange-50 opacity-10 group-hover:scale-110 transition-transform">
          <svg width="120" height="120" fill="currentColor" viewBox="0 0 24 24"><path d="M13.5 5.5c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zM9.8 8.9L7 10.2l.6 3.5 1.8-1.5L10 16.5l2-1.6.7 3.6 2-1.2-.8-4.1-2.2-2.3 2.1-1.1 2 2.3 1.5-1.1-2.5-3-3.6 1.8-1.7-2.1-2.7 1.2z"/></svg>
        </div>
        <h2 class="text-[10px] font-black text-gray-400 uppercase tracking-[0.2em] mb-8">Personal Summary</h2>
        <div class="space-y-6">
          <div>
            <p id="stat-runs" class="text-5xl font-black text-gray-800 tracking-tighter leading-none">0</p>
            <p class="text-[10px] font-bold text-gray-400 uppercase mt-2">Total Activities</p>
          </div>
          <div>
            <p id="stat-dist" class="text-5xl font-black text-gray-800 tracking-tighter leading-none">0.0</p>
            <p class="text-[10px] font-bold text-gray-400 uppercase mt-2">Total Kilometers</p>
          </div>
        </div>
      </div>

      <div class="bg-white p-6 rounded-[40px] shadow-sm border border-gray-100">
        <h3 class="text-[10px] font-black text-gray-400 uppercase tracking-widest mb-4">7-Day Progress (KM)</h3>
        <div class="h-48 w-full relative">
          <canvas id="weeklyChart"></canvas>
        </div>
      </div>

      <div class="bg-orange-600 p-8 rounded-[40px] text-white shadow-2xl shadow-orange-200">
         <h3 class="text-[10px] font-black opacity-70 uppercase tracking-widest mb-4 italic text-orange-100">Action Centre</h3>
         <p class="text-sm font-bold leading-relaxed mb-6 text-white">Import via GPX atau lari langsung sekarang!</p>
         <div class="flex flex-col gap-3">
           <label class="w-full cursor-pointer bg-orange-700 hover:bg-orange-800 text-white py-4 rounded-2xl text-[10px] font-black transition-all text-center uppercase tracking-widest">
             <span id="gpx-label">Import GPX File</span>
             <input type="file" id="gpx-input" accept=".gpx" class="hidden" />
           </label>
           <a href="/tracker" class="w-full bg-white text-orange-600 py-4 rounded-2xl text-[10px] font-black text-center shadow-lg hover:scale-[1.02] transition-all uppercase tracking-widest">
             Start New Run
           </a>
         </div>
      </div>
    </aside>

    <section class="col-span-1 lg:col-span-2 space-y-4">
      <h2 class="font-black italic text-gray-800 uppercase tracking-tight ml-2">Recent Activities</h2>
      <div id="activities-list" class="space-y-4">
         <div class="animate-pulse flex flex-col gap-4">
           <div class="h-24 bg-gray-200 rounded-[32px]"></div>
           <div class="h-24 bg-gray-200 rounded-[32px]"></div>
         </div>
      </div>
    </section>
  </main>
</Layout>

<script>
  import { supabase } from '../lib/supabase';

  const loader = document.getElementById('global-loader');
  const content = document.getElementById('dashboard-content');
  const activitiesList = document.getElementById('activities-list');
  const gpxInput = document.getElementById('gpx-input') as HTMLInputElement;
  const gpxLabel = document.getElementById('gpx-label');

  let weeklyChart: any = null;

  // --- Helper: Hitung Jarak ---
  function getDistance(lat1: number, lon1: number, lat2: number, lon2: number) {
    const R = 6371;
    const dLat = (lat2 - lat1) * Math.PI / 180;
    const dLon = (lon2 - lon1) * Math.PI / 180;
    const a = Math.sin(dLat/2) * Math.sin(dLat/2) +
              Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) *
              Math.sin(dLon/2) * Math.sin(dLon/2);
    return R * (2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a)));
  }

  // --- Logika Import GPX ---
  gpxInput?.addEventListener('change', async (e) => {
    const file = (e.target as HTMLInputElement).files?.[0];
    if (!file) return;

    if (gpxLabel) gpxLabel.innerText = "Processing File...";

    try {
      const gpxText = await file.text();
      const parser = new DOMParser();
      const gpxXml = parser.parseFromString(gpxText, "text/xml");
      const trkpts = Array.from(gpxXml.querySelectorAll('trkpt'));

      if (trkpts.length === 0) throw new Error("GPX tidak memiliki koordinat.");

      let cumulativeDistance = 0;
      let routeData: any[] = [];
      const startTimeStr = trkpts[0].querySelector('time')?.textContent;
      if (!startTimeStr) throw new Error("Data waktu tidak ditemukan.");
      const startTime = new Date(startTimeStr).getTime();

      trkpts.forEach((pt, index) => {
        const lat = parseFloat(pt.getAttribute('lat') || '0');
        const lon = parseFloat(pt.getAttribute('lon') || '0');
        const timeStr = pt.querySelector('time')?.textContent;
        
        if (index > 0) {
          const prev = trkpts[index - 1];
          cumulativeDistance += getDistance(
            parseFloat(prev.getAttribute('lat') || '0'),
            parseFloat(prev.getAttribute('lon') || '0'),
            lat, lon
          );
        }

        const elapsedSec = timeStr ? Math.floor((new Date(timeStr).getTime() - startTime) / 1000) : 0;
        routeData.push({ lat, lng: lon, time: elapsedSec, dist: cumulativeDistance });
      });

      const title = prompt("Nama Lari:", "Morning Run (GPX)") || "Imported Run";
      const { data: { session } } = await supabase.auth.getSession();
      
      const { error } = await supabase.from('activities').insert([{
        title,
        distance: parseFloat(cumulativeDistance.toFixed(2)),
        duration: routeData[routeData.length - 1].time,
        user_id: session?.user?.id,
        route_data: routeData,
        created_at: new Date(startTime).toISOString()
      }]);

      if (error) throw error;
      window.location.reload();
    } catch (err: any) {
      alert(err.message);
      if (gpxLabel) gpxLabel.innerText = "Import GPX File";
    }
  });

  async function initDashboard() {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) { window.location.href = '/login'; return; }

    const user = session.user;
    loader?.classList.add('hidden');
    content?.classList.remove('hidden');

    const nameEl = document.getElementById('user-name');
    if (nameEl) nameEl.innerText = `Athlete: ${user.user_metadata.full_name || user.email}`;
    const avatar = document.getElementById('user-avatar') as HTMLImageElement;
    if (user.user_metadata.avatar_url && avatar) {
        avatar.src = user.user_metadata.avatar_url;
        avatar.classList.remove('hidden');
    }

    await loadActivities(user.id);
  }

  async function loadActivities(userId: string) {
    const { data: activities, error } = await supabase
      .from('activities')
      .select('*')
      .eq('user_id', userId)
      .order('created_at', { ascending: false });

    if (!error && activities) {
      const totalDist = activities.reduce((acc, curr) => acc + (curr.distance || 0), 0);
      const runsEl = document.getElementById('stat-runs');
      const distEl = document.getElementById('stat-dist');
      if (runsEl) runsEl.innerText = activities.length.toString();
      if (distEl) distEl.innerText = totalDist.toFixed(1);

      renderChart(activities);

      if (activitiesList) {
        if (activities.length === 0) {
          activitiesList.innerHTML = `<div class="text-center py-20 bg-white rounded-[40px] border-2 border-dashed border-gray-100"><p class="text-gray-300 font-black italic uppercase tracking-widest text-xs">No runs recorded yet.</p></div>`;
        } else {
          activitiesList.innerHTML = activities.map(run => `
            <a href="/run/${run.id}" class="block bg-white p-6 rounded-[32px] border border-gray-50 hover:border-orange-200 shadow-sm transition-all group active:scale-[0.98]">
              <div class="flex justify-between items-center">
                <div>
                  <h3 class="font-black text-gray-800 text-xl italic uppercase group-hover:text-orange-600 transition-colors leading-none">${run.title}</h3>
                  <p class="text-[10px] font-bold text-gray-400 mt-3 uppercase tracking-widest">
                    📅 ${new Date(run.created_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' })}
                  </p>
                </div>
                <div class="text-right">
                  <p class="text-3xl font-black text-gray-800 leading-none">${(run.distance || 0).toFixed(2)}<span class="text-xs ml-1 text-gray-400 font-bold uppercase italic">km</span></p>
                  <p class="text-[10px] font-black text-orange-500 uppercase italic mt-2 tracking-tighter">View Stats →</p>
                </div>
              </div>
            </a>
          `).join('');
        }
      }
    }
  }

  function renderChart(activities: any[]) {
    const canvas = document.getElementById('weeklyChart') as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const days = [];
    const distances = [];
    for (let i = 6; i >= 0; i--) {
      const d = new Date();
      d.setDate(d.getDate() - i);
      days.push(d.toLocaleDateString('id-ID', { weekday: 'short' }));
      const totalDay = activities
        .filter(a => new Date(a.created_at).toDateString() === d.toDateString())
        .reduce((sum, current) => sum + (current.distance || 0), 0);
      distances.push(totalDay);
    }

    if (weeklyChart) weeklyChart.destroy();
    // @ts-ignore
    weeklyChart = new Chart(ctx, {
      type: 'bar',
      data: {
        labels: days,
        datasets: [{ label: 'KM', data: distances, backgroundColor: '#ea580c', borderRadius: 8, barThickness: 12 }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: { 
            y: { beginAtZero: true, display: false }, 
            x: { grid: { display: false }, ticks: { font: { size: 9, weight: 'bold' } } } 
        }
      }
    });
  }

  document.getElementById('logout-btn')?.addEventListener('click', async () => {
    await supabase.auth.signOut();
    window.location.href = '/login';
  });

  initDashboard();
</script>
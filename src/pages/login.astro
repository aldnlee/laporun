---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Login - Ngabuburun">
  <main class="h-screen flex flex-col items-center justify-center p-6 bg-white font-sans">
    <div class="text-center mb-12">
      <div class="w-20 h-20 bg-orange-100 rounded-3xl flex items-center justify-center mx-auto mb-6 rotate-3">
        <span class="text-4xl">🏃‍♂️</span>
      </div>
      <h1 class="text-4xl font-black italic text-gray-800 tracking-tighter uppercase">Ngabuburun</h1>
      <p class="text-gray-400 font-bold mt-2 text-[10px] uppercase tracking-[0.3em]">Track your run, chase the sun</p>
    </div>
    <button id="google-login" class="w-full max-w-xs flex items-center justify-center gap-3 bg-white border-2 border-gray-100 py-4 rounded-2xl font-bold text-gray-700 hover:border-orange-200 transition-all shadow-sm">
      <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" class="w-5 h-5" alt="Google">
      Continue with Google
    </button>
  </main>
</Layout>

<script>
  import { supabase } from '../lib/supabase';
  document.getElementById('google-login')?.addEventListener('click', async () => {
    await supabase.auth.signInWithOAuth({
      provider: 'google',
      options: { redirectTo: window.location.origin }
    });
  });
</script>
---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Tracker - Ngabuburun">
  <main class="p-4 max-w-xl mx-auto font-sans flex flex-col h-screen bg-gray-50">
    
    <div class="bg-white rounded-[32px] p-6 shadow-sm mb-4 border border-gray-100">
        <div class="flex justify-between items-center mb-4">
           <div class="flex items-center gap-2">
             <div id="gps-dot" class="w-2 h-2 rounded-full bg-red-500 animate-pulse"></div>
             <span id="gps-badge" class="text-[10px] font-black text-gray-400 uppercase tracking-widest">Searching GPS</span>
           </div>
           <span id="display-time" class="text-2xl font-black font-mono text-gray-800">00:00</span>
        </div>
        
        <div class="text-center py-2">
           <p id="display-distance" class="text-8xl font-black text-orange-600 tracking-tighter">0.00</p>
           <p class="text-[10px] font-black text-gray-300 uppercase tracking-[0.3em]">Kilometers</p>
        </div>

        <div class="grid grid-cols-2 gap-4 mt-6 pt-6 border-t border-gray-50">
           <div class="text-center">
             <p id="display-pace" class="text-xl font-black text-gray-800 font-mono">0'00"</p>
             <p class="text-[10px] font-bold text-gray-400 uppercase">Current Pace</p>
           </div>
           <div class="text-center flex flex-col items-center justify-center">
             <div id="offline-indicator" class="hidden flex items-center gap-1 text-[8px] font-black text-orange-500 bg-orange-50 px-2 py-1 rounded-full uppercase">
                Offline Mode
             </div>
             <p id="display-steps" class="text-xl font-black text-gray-800 font-mono mt-1">Ready</p>
             <p class="text-[10px] font-bold text-gray-400 uppercase">Status</p>
           </div>
        </div>
    </div>

    <div class="relative flex-grow rounded-[32px] overflow-hidden mb-4 border-4 border-white shadow-xl">
      <div id="map" class="h-full w-full z-0"></div>
      <button id="recenter-btn" class="absolute bottom-4 right-4 z-[1000] bg-white/90 backdrop-blur p-3 rounded-2xl shadow-lg border border-white active:scale-90 transition-all">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
        </svg>
      </button>
    </div>

    <div class="py-2">
      <button id="start-btn" disabled class="w-full bg-gray-200 text-gray-400 py-5 rounded-[24px] font-black text-xl shadow-lg transition-all cursor-not-allowed uppercase italic tracking-widest">
        Waiting for GPS...
      </button>
      <button id="stop-btn" class="hidden w-full bg-red-500 hover:bg-red-600 text-white py-5 rounded-[24px] font-black text-xl shadow-lg shadow-red-100 uppercase italic tracking-widest transition-all">
        Finish & Save
      </button>
    </div>
  </main>
</Layout>

<script>
  // @ts-ignore
  import L from 'leaflet';
  import 'leaflet/dist/leaflet.css';
  import { supabase } from '../lib/supabase';
  import { saveRunLocally } from '../lib/db'; // Asumsi kamu sudah buat Step 3

  const startBtn = document.getElementById('start-btn') as HTMLButtonElement;
  const stopBtn = document.getElementById('stop-btn') as HTMLButtonElement;
  const badge = document.getElementById('gps-badge')!;
  const dot = document.getElementById('gps-dot')!;
  const distanceEl = document.getElementById('display-distance')!;
  const timeEl = document.getElementById('display-time')!;
  const paceEl = document.getElementById('display-pace')!;
  const recenterBtn = document.getElementById('recenter-btn')!;
  const offlineBadge = document.getElementById('offline-indicator')!;

  let map: L.Map, marker: L.CircleMarker, pathLine: L.Polyline;
  let startTime: number, timerInterval: any;
  let lastCoords: L.LatLng | null = null;
  let totalDistance = 0;
  let routeCoords: any[] = [];
  let isRunning = false;
  let currentUser: any = null;

  async function initTracker() {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) { window.location.href = '/login'; return; }
    currentUser = session.user;

    map = L.map('map', { zoomControl: false }).setView([-6.3024, 106.7551], 16);
    L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png').addTo(map);

    // Monitor koneksi secara real-time
    window.addEventListener('online', () => offlineBadge.classList.add('hidden'));
    window.addEventListener('offline', () => offlineBadge.classList.remove('hidden'));
    if (!navigator.onLine) offlineBadge.classList.remove('hidden');

    startGPSWatch();
  }

  function startGPSWatch() {
    if (!navigator.geolocation) return alert("GPS Not Supported");

    navigator.geolocation.watchPosition((pos) => {
      const { latitude, longitude, accuracy } = pos.coords;
      const current = new L.LatLng(latitude, longitude);

      // Filter GPS Jitter
      if (accuracy < 50) {
        badge.innerText = "GPS READY";
        badge.className = "text-[10px] font-black text-green-500 uppercase tracking-widest";
        dot.className = "w-2 h-2 rounded-full bg-green-500 animate-ping";
        if (!isRunning) {
          startBtn.disabled = false;
          startBtn.innerText = "Start Running";
          startBtn.className = "w-full bg-orange-500 text-white py-5 rounded-[24px] font-black text-xl shadow-lg active:scale-95 transition-all uppercase italic tracking-widest cursor-pointer";
        }
      }

      if (!marker) {
        marker = L.circleMarker(current, { radius: 10, fillColor: '#3b82f6', color: '#fff', fillOpacity: 1, weight: 4 }).addTo(map);
        map.flyTo(current, 17);
      } else {
        marker.setLatLng(current);
      }

      if (isRunning && lastCoords) {
        const d = lastCoords.distanceTo(current) / 1000;
        // Hanya rekam jika berpindah lebih dari 2 meter untuk akurasi heatmap
        if (d > 0.002 && accuracy < 60) { 
          totalDistance += d;
          const elapsedSec = Math.floor((Date.now() - startTime) / 1000);

          routeCoords.push({
            lat: latitude,
            lng: longitude,
            time: elapsedSec,
            dist: totalDistance
          });

          distanceEl.innerText = totalDistance.toFixed(2);

          // Update jalur lari di peta
          const pathPoints = routeCoords.map(p => [p.lat, p.lng]);
          if (pathLine) {
            pathLine.setLatLngs(pathPoints as L.LatLngExpression[]);
          } else {
            pathLine = L.polyline(pathPoints as L.LatLngExpression[], { color: '#ea580c', weight: 6, opacity: 0.9, lineJoin: 'round' }).addTo(map);
          }

          // Kalkulasi Pace Real-time
          const currentPace = (elapsedSec / 60) / totalDistance;
          const pMin = Math.floor(currentPace);
          const pSec = Math.round((currentPace - pMin) * 60);
          if (pMin < 20) paceEl.innerText = `${pMin}'${pSec.toString().padStart(2, '0')}"`;
        }
      }
      lastCoords = current;
    }, (err) => console.error(err), { 
      enableHighAccuracy: true,
      maximumAge: 1000,
      timeout: 10000 
    });
  }

  startBtn.addEventListener('click', () => {
    isRunning = true;
    startTime = Date.now();
    startBtn.classList.add('hidden');
    stopBtn.classList.remove('hidden');

    timerInterval = setInterval(() => {
      const diff = Date.now() - startTime;
      const m = Math.floor(diff / 60000);
      const s = Math.floor((diff % 60000) / 1000);
      timeEl.innerText = `${m.toString().padStart(2, '0')}:${s.toString().padStart(2, '0')}`;
    }, 1000);
  });

  stopBtn.addEventListener('click', async () => {
    const activityName = prompt("Beri nama lari kamu, Den:", "Ngabuburun Sore");
    if (!activityName) return;

    stopBtn.disabled = true;
    stopBtn.innerText = "Processing...";
    clearInterval(timerInterval);

    const runData = {
      title: activityName,
      distance: parseFloat(totalDistance.toFixed(2)),
      duration: Math.floor((Date.now() - startTime) / 1000),
      user_id: currentUser?.id,
      route_data: routeCoords,
      created_at: new Date().toISOString()
    };

    // --- OFFINE-FIRST LOGIC ---
    if (!navigator.onLine) {
      await saveRunLocally(runData);
      alert("Lari disimpan secara offline! Data akan sinkron otomatis saat kamu online.");
      window.location.href = '/';
      return;
    }

    try {
      const { error } = await supabase.from('activities').insert([runData]);
      if (error) throw error;
      window.location.href = '/';
    } catch (err: any) {
      console.warn("Upload gagal, menyimpan ke lokal...", err);
      await saveRunLocally(runData);
      alert("Gagal koneksi ke server. Data lari tetap aman di HP kamu (Offline Mode).");
      window.location.href = '/';
    }
  });

  recenterBtn.addEventListener('click', () => { if (lastCoords) map.flyTo(lastCoords, 17); });

  initTracker();
</script>

<style>
  :global(.leaflet-control-attribution) { display: none; }
  .leaflet-interactive { filter: drop-shadow(0 0 4px rgba(234, 88, 12, 0.4)); }
</style>
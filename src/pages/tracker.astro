---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Tracker - Ngabuburun">
  <main class="p-4 max-w-xl mx-auto font-sans flex flex-col h-screen bg-gray-50">
    <div class="bg-white rounded-3xl p-6 shadow-sm mb-4">
       <div class="flex justify-between items-center mb-2">
          <span id="gps-badge" class="px-2 py-1 rounded-full text-[10px] font-bold bg-red-100 text-red-600 uppercase">GPS OFF</span>
          <span id="display-time" class="text-xl font-black font-mono text-gray-800">00:00</span>
       </div>
       <div class="text-center">
          <p id="display-distance" class="text-7xl font-black text-orange-600">0.00</p>
          <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Kilometer</p>
       </div>
    </div>

    <div class="relative flex-grow rounded-3xl overflow-hidden mb-4 border-2 border-white shadow-lg">
      <div id="map" class="h-full w-full"></div>
    </div>

    <div class="py-4">
      <button id="start-btn" disabled class="w-full bg-gray-300 text-white py-5 rounded-2xl font-black text-xl shadow-lg transition-all">
        WAITING FOR GPS...
      </button>
      <button id="stop-btn" class="hidden w-full bg-red-500 text-white py-5 rounded-2xl font-black text-xl shadow-lg">
        FINISH
      </button>
    </div>
  </main>
</Layout>

<script>
  import L from 'leaflet';
  import 'leaflet/dist/leaflet.css';
  import { supabase } from '../lib/supabase';

  const startBtn = document.getElementById('start-btn') as HTMLButtonElement;
  const stopBtn = document.getElementById('stop-btn') as HTMLButtonElement;
  const badge = document.getElementById('gps-badge')!;
  const distanceEl = document.getElementById('display-distance')!;
  
  let map: L.Map, marker: L.CircleMarker, watchId: any, startTime: any;
  let lastCoords: L.LatLng | null = null;
  let totalDistance = 0;
  let routeCoords: any[] = [];

  // Init Map
  map = L.map('map', { zoomControl: false }).setView([-6.3024, 106.7551], 16);
  L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png').addTo(map);

  // 1. PRE-RUN LOCK (Langsung cari posisi)
  const initWatch = navigator.geolocation.watchPosition((pos) => {
    const { latitude, longitude, accuracy } = pos.coords;
    const current = new L.LatLng(latitude, longitude);

    if (accuracy < 40) {
      badge.innerText = "GPS READY";
      badge.className = "px-2 py-1 rounded-full text-[10px] font-bold bg-green-100 text-green-600 uppercase";
      startBtn.disabled = false;
      startBtn.innerText = "START RUNNING";
      startBtn.className = "w-full bg-orange-500 text-white py-5 rounded-2xl font-black text-xl shadow-lg active:scale-95 transition-all";
    }

    if (!marker) {
      marker = L.circleMarker(current, { radius: 8, fillColor: '#3b82f6', color: '#fff', fillOpacity: 1, weight: 3 }).addTo(map);
      map.flyTo(current, 17);
    } else {
      marker.setLatLng(current);
    }
    lastCoords = current;
  }, (err) => console.error(err), { enableHighAccuracy: true });

  // 2. START & STOP LOGIC
  startBtn.addEventListener('click', () => {
    startTime = Date.now();
    startBtn.classList.add('hidden');
    stopBtn.classList.remove('hidden');
    // Tambahkan logic tracking lari di sini (sama seperti code sebelumnya)
  });

  stopBtn.addEventListener('click', async () => {
    // RENAME SETELAH FINISH
    const activityName = prompt("Kasih nama lari kamu, Den:", "Ngabuburun Sore");
    
    if (activityName !== null) {
      stopBtn.disabled = true;
      stopBtn.innerText = "SAVING...";

      const { error } = await supabase.from('activities').insert([{
        title: activityName,
        distance: parseFloat(totalDistance.toFixed(2)),
        duration: Math.floor((Date.now() - startTime) / 1000),
        created_at: new Date().toISOString()
      }]);

      if (!error) window.location.href = '/';
    }
  });
</script>
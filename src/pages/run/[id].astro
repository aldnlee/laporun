---
import Layout from '../../layouts/Layout.astro';
import { supabase } from '../../lib/supabase';

const { id } = Astro.params;
const { data: run } = await supabase.from('activities').select('*').eq('id', id).single();

if (!run) return Astro.redirect('/');
---

<Layout title="Detail Lari">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  
  <main class="p-6 max-w-xl mx-auto">
    <a href="/" class="text-orange-500 mb-4 block">← Kembali</a>
    <h1 class="text-2xl font-bold">{run.title}</h1>
    <p class="text-gray-500 mb-6">{new Date(run.created_at).toLocaleString('id-ID')}</p>

    <div id="map" class="h-64 w-full rounded-2xl mb-6 shadow-inner bg-gray-100"></div>

    <div class="grid grid-cols-3 gap-2 text-center">
      <div class="p-2 border rounded-lg">
        <p class="text-xs text-gray-400">Jarak</p>
        <p class="font-bold">{run.distance.toFixed(2)} km</p>
      </div>
      <div class="p-2 border rounded-lg">
        <p class="text-xs text-gray-400">Waktu</p>
        <p class="font-bold">{Math.floor(run.duration / 60)}m</p>
      </div>
      <div class="p-2 border rounded-lg">
        <p class="text-xs text-gray-400">Pace</p>
        <p class="font-bold">{(run.duration / 60 / run.distance).toFixed(2)} /km</p>
      </div>
    </div>
  </main>

  <script define:vars={{ coords: run.coords }}>
    // Script ini berjalan di browser
    import L from 'leaflet';
    
    if (coords && coords.length > 0) {
      const map = L.map('map').setView([coords[0].lat, coords[0].lng], 15);
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);

      const path = coords.map(c => [c.lat, c.lng]);
      L.polyline(path, { color: '#f97316', weight: 5 }).addTo(map);
      map.fitBounds(L.polyline(path).getBounds());
    }
  </script>
</Layout>
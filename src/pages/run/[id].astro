---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Activity Detail - Ngabuburun">
  <main class="p-6 max-w-3xl mx-auto font-sans bg-gray-50 min-h-screen">
    <nav class="flex justify-between items-center mb-8">
      <a href="/" class="text-[10px] font-black text-gray-400 uppercase tracking-widest hover:text-orange-600 transition-colors">
        ← Back to Dashboard
      </a>
      <div class="bg-orange-100 text-orange-600 px-4 py-1 rounded-full text-[10px] font-black uppercase tracking-widest">
        Activity Detail
      </div>
    </nav>

    <div class="bg-white rounded-[40px] shadow-sm border border-gray-100 overflow-hidden mb-6">
      <div class="p-8 border-b border-gray-50">
        <h1 id="detail-title" class="text-4xl font-black italic text-gray-800 uppercase tracking-tighter mb-2 italic">Loading...</h1>
        <p id="detail-date" class="text-xs font-bold text-gray-400 uppercase tracking-widest"></p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-px bg-gray-100">
        <div class="bg-white p-8">
          <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest mb-2">Distance</p>
          <p id="detail-dist" class="text-4xl font-black text-gray-800 italic">0.00<span class="text-sm ml-1 uppercase text-gray-400">km</span></p>
        </div>
        <div class="bg-white p-8">
          <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest mb-2">Duration</p>
          <p id="detail-dur" class="text-4xl font-black text-gray-800 italic">00:00:00</p>
        </div>
        <div class="bg-white p-8 col-span-2 md:col-span-1 border-t md:border-t-0">
          <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest mb-2">Avg. Pace</p>
          <p id="detail-pace" class="text-4xl font-black text-orange-600 italic">0'00"</p>
        </div>
      </div>

      <div id="detail-map" class="h-80 w-full bg-gray-200 z-0"></div>
    </div>

    <div id="splits-container" class="bg-white rounded-[32px] p-6 shadow-sm border border-gray-100 mb-6 hidden">
      <h2 class="text-[10px] font-black text-gray-400 uppercase tracking-[0.2em] mb-4">Kilometer Splits</h2>
      <div id="splits-list" class="space-y-2">
        </div>
    </div>

    <div class="mt-8 flex gap-4">
      <button id="delete-btn" class="flex-1 bg-white border-2 border-red-50 text-red-400 py-4 rounded-3xl text-xs font-black uppercase tracking-widest hover:bg-red-50 transition-all">
        Delete Run
      </button>
      <button class="flex-1 bg-gray-800 text-white py-4 rounded-3xl text-xs font-black uppercase tracking-widest hover:bg-gray-900 transition-all">
        Share Stats
      </button>
    </div>
  </main>
</Layout>

<script>
  // @ts-ignore
  import L from 'leaflet';
  import 'leaflet/dist/leaflet.css';
  import { supabase } from '../../lib/supabase';

  const runId = window.location.pathname.split('/').pop();
  const deleteBtn = document.getElementById('delete-btn');

  async function loadDetail() {
    const { data: run, error } = await supabase.from('activities').select('*').eq('id', runId).single();
    if (error || !run) { window.location.href = '/'; return; }

    document.getElementById('detail-title')!.innerText = run.title;
    document.getElementById('detail-dist')!.innerHTML = `${run.distance.toFixed(2)}<span class="text-sm ml-1 uppercase text-gray-400">km</span>`;
    document.getElementById('detail-dur')!.innerText = new Date(run.duration * 1000).toISOString().substr(11, 8);
    document.getElementById('detail-date')!.innerText = `📅 ${new Date(run.created_at).toLocaleDateString('id-ID', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' })}`;

    if (run.distance > 0) {
      const pace = (run.duration / 60) / run.distance;
      const min = Math.floor(pace);
      const sec = Math.round((pace - min) * 60);
      document.getElementById('detail-pace')!.innerText = `${min}'${sec.toString().padStart(2, '0')}"`;
      
      // GENERATE SPLITS (Simulasi sederhana berdasarkan avg pace)
      renderSplits(run.distance, run.duration);
    }

    if (run.route_data && run.route_data.length > 0) {
      const map = L.map('detail-map', { zoomControl: false });
      L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png').addTo(map);
      const polyline = L.polyline(run.route_data, { color: '#ea580c', weight: 6, opacity: 0.9, lineJoin: 'round' }).addTo(map);
      map.fitBounds(polyline.getBounds(), { padding: [40, 40] });
    }
  }

  function renderSplits(distance: number, duration: number) {
    const container = document.getElementById('splits-container');
    const list = document.getElementById('splits-list');
    if (!container || !list) return;

    container.classList.remove('hidden');
    const totalKm = Math.ceil(distance);
    let html = '';

    for (let i = 1; i <= totalKm; i++) {
      // Logic: Split per KM (Saat ini simulasi flat pace, bisa dikembangkan dengan data koordinat)
      const isLast = i === totalKm;
      const kmDistance = isLast ? (distance % 1 || 1) : 1;
      const avgPaceSec = (duration / distance);
      const splitPace = avgPaceSec; // Untuk akurasi tinggi, butuh data timestamp per koordinat
      
      const min = Math.floor(splitPace / 60);
      const sec = Math.round(splitPace % 60);

      html += `
        <div class="flex justify-between items-center py-2 border-b border-gray-50 last:border-0">
          <span class="text-[10px] font-black text-gray-400 uppercase tracking-widest">KM ${i}</span>
          <span class="font-mono font-bold text-gray-800">${min}'${sec.toString().padStart(2, '0')}"</span>
        </div>
      `;
    }
    list.innerHTML = html;
  }

  deleteBtn?.addEventListener('click', async () => {
    if (confirm('Hapus?')) {
      await supabase.from('activities').delete().eq('id', runId);
      window.location.href = '/';
    }
  });

  loadDetail();
</script>
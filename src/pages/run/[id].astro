---
import Layout from '../../layouts/Layout.astro';
import { supabase } from '../../lib/supabase';

const { id } = Astro.params;
const { data: run } = await supabase.from('activities').select('*').eq('id', id).single();

if (!run) return Astro.redirect('/');
---

<Layout title="Detail Lari">
  <main class="p-6 max-w-xl mx-auto bg-white min-h-screen">
    <a href="/" class="text-orange-500 font-bold text-sm">← KEMBALI</a>
    
    <div class="mt-8">
      <h1 class="text-4xl font-black text-gray-800">{run.title}</h1>
      <p class="text-gray-400 font-bold uppercase">{new Date(run.created_at).toLocaleString()}</p>
    </div>

    <div class="grid grid-cols-2 gap-4 my-10">
      <div class="bg-orange-50 p-6 rounded-3xl">
        <p class="text-5xl font-black text-orange-600">{run.distance}</p>
        <p class="text-xs font-bold text-orange-400 italic tracking-widest">KILOMETER</p>
      </div>
      <div class="bg-gray-50 p-6 rounded-3xl">
        <p class="text-3xl font-black text-gray-800">{Math.floor(run.duration / 60)}m {run.duration % 60}s</p>
        <p class="text-xs font-bold text-gray-400 italic tracking-widest">DURATION</p>
      </div>
    </div>
    
    </main>
</Layout>